{
  "LambdaFunctionConfigurations": [
    {
      "LambdaFunctionArn": "arn:aws:lambda:us-east-1:465768368095:function:security-log-lake-parser",
      "Events": ["s3:ObjectCreated:*"],
      "Filter": {
        "Key": {
          "FilterRules": [
            { "Name": "prefix", "Value": "raw/" },
            { "Name": "suffix", "Value": ".csv" }
          ]
        }
      }
    }
  ]
}